{
  "headers": [
    {
      "source": "/_expo/static/js/web/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "buildCommand": "bash deploy.sh",
  "outputDirectory": "dist",
  "installCommand": "npm install"
}
